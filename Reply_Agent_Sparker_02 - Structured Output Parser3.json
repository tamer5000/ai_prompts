{
  "type": "object",
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "browsing",
        "ordering",
        "updating",
        "confirmation",
        "objection",
        "question"
      ]
    },

    "reply": {
      "type": "string"
    },

    "stage": {
      "type": "string",
      "enum": [
        "browsing",
        "selecting_product",
        "selecting_size",
        "selecting_color",
        "collecting_customer_info",
        "order_review",
        "order_complete",
        "order_updated"
      ]
    },

    "send_images": {
      "type": "boolean"
    },

    "image_urls": {
      "type": "array",
      "maxItems": 1,
      "items": {
        "type": "string"
      }
    },

    "order_data": {
      "type": "object",
      "properties": {
        "customer_name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "mobile": {
          "type": "string"
        }
      },
      "required": [
        "customer_name",
        "address",
        "mobile"
      ]
    },

    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "product_code": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "size": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "quantity": {
            "type": "number",
            "minimum": 1
          },
          "price": {
            "type": "number",
            "minimum": 1
          }
        },
        "required": [
          "product_code",
          "product_name",
          "size",
          "color",
          "quantity",
          "price"
        ]
      }
    },

    "order_total": {
      "type": "number"
    },

    "order_status": {
      "type": "string",
      "enum": [
        "draft",
        "created",
        "updating",
        "updated",
        "confirmed"
      ]
    },

    "order_id": {
      "type": "string"
    },

    "trigger_webhook": {
      "type": "boolean"
    },

    "event_type": {
      "type": "string",
      "enum": [
        "",
        "order_created",
        "order_modify_request"
      ]
    },

    "escalation": {
      "type": "object",
      "properties": {
        "required": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "enum": [
            "",
            "modify_request"
          ]
        },
        "reason": {
          "type": "string"
        }
      },
      "required": [
        "required",
        "type",
        "reason"
      ]
    }
  },

  "required": [
    "intent",
    "reply",
    "stage",
    "send_images",
    "image_urls",
    "order_data",
    "items",
    "order_total",
    "order_status",
    "order_id",
    "trigger_webhook",
    "event_type",
    "escalation"
  ]
}
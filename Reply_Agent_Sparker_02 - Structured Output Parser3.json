        "asking_price",
        "asking_sizes",
        "asking_colors",
        "asking_shipping",
        "asking_photos",
        "interested",
        "objection",
        "ordering",
        "unknown"
      ]
    },
    "reply": { "type": "string" },
    "stage": {
      "type": "string",
      "enum": ["new", "interested", "ordering"]
    },
    "send_images": { "type": "boolean" },
